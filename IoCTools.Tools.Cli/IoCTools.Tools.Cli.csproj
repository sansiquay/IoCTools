<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>ioc-tools</ToolCommandName>
        <AssemblyName>IoCTools.Tools.Cli</AssemblyName>
        <RootNamespace>IoCTools.Tools.Cli</RootNamespace>
        <PackageId>IoCTools.Tools.Cli</PackageId>
        <Version>1.3.0</Version>
        <Description>Developer-facing CLI for IoCTools: fields, services, explain, graph, why, doctor, compare, profile, config-audit.</Description>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="IoCTools.Tools.Cli.Tests" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\IoCTools.Generator\IoCTools.Generator\IoCTools.Generator.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Build.Locator" Version="1.10.12"/>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.5.0"/>
        <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="4.5.0"/>
    </ItemGroup>

</Project>
