<Project>
  <!--
    IoCTools.Generator.targets

    Exposes MSBuild properties to the source generator analyzer, allowing users
    to configure IoCTools behavior via their .csproj files.
  -->
  <ItemGroup>
    <CompilerVisibleProperty Include="IoCToolsIgnoredTypePatterns" />
    <!-- 1.6 auto-deps resolver properties -->
    <CompilerVisibleProperty Include="IoCToolsAutoDepsDisable" />
    <CompilerVisibleProperty Include="IoCToolsAutoDepsExcludeGlob" />
    <CompilerVisibleProperty Include="IoCToolsAutoDepsReport" />
    <CompilerVisibleProperty Include="IoCToolsAutoDetectLogger" />
    <CompilerVisibleProperty Include="IoCToolsInjectDeprecationSeverity" />
  </ItemGroup>
</Project>
